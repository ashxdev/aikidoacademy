---
import type { CollectionEntry } from 'astro:content'
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

type Props = CollectionEntry<'blog'>['data']

const { title, description } = Astro.props
---

<html lang="uk-UA" class="js-on csstransforms csstransforms3d csstransitions">
  <!--[if lt IE 7]>   <html dir="ltr" lang="en-US" class="lt-ie9 lt-ie8 lt-ie7"><![endif]--><!--[if IE 7]>      <html dir="ltr" lang="en-US" class="lt-ie9 lt-ie8"><![endif]--><!--[if IE 8]>      <html dir="ltr" lang="en-US" class="lt-ie9"><![endif]--><!--[if IE 9]>      <html dir="ltr" lang="en-US"  class="lt-ie10"> <![endif]--><!--[if gt IE 9]> <html dir="ltr" lang="en-US" class="gt-ie9 non-ie"> <![endif]-->
  <head>
    <BaseHead {title} {description} />
  </head>
  <body id="top" class="boxed stickymenu stickyfooter" style="">
    <script type="text/javascript" src="/js/addthis_widget.js" async="async"></script>



    <div id="wrapper" style="margin-bottom: 75px;">
      <Header />
      <slot />
      <Footer />
    </div>

<button id="mobileScrollTop" title="Вгору"></button>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const btn = document.getElementById('mobileScrollTop');
  if (!btn) return;

  window.addEventListener('scroll', () => {
    if (window.innerWidth <= 768) {
      if (window.scrollY > 300) {
        btn.style.opacity = '1';
        btn.style.pointerEvents = 'auto';
      } else {
        btn.style.opacity = '0';
        btn.style.pointerEvents = 'none';
      }
    }
  });

  btn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
});
</script>

<script>
window.onload = function () {
  const nav = document.getElementById('primary-navigation') as HTMLElement;
  if (!nav) return;

  // створюємо placeholder одразу після меню
  const placeholder = document.createElement('div');
  placeholder.id = 'mobile-nav-placeholder';
  nav.after(placeholder);

  function handleScroll() {
    if (window.innerWidth <= 768 && window.scrollY > 120) {
      nav.classList.add('mobile-sticky');
      placeholder.style.display = 'block';
    } else {
      nav.classList.remove('mobile-sticky');
      placeholder.style.display = 'none';
    }
  }

  window.addEventListener('scroll', handleScroll);
  handleScroll();
};
</script>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const nav = document.getElementById('primary-navigation');
  if (!nav) return;

  let lastScroll = 0;
  let triggered = false;

  window.addEventListener('scroll', () => {
    const current = window.scrollY;

    // момент "дотику" до верху
    if (current > 160 && !triggered) {
      nav.classList.add('mobile-hide');

      setTimeout(() => {
        nav.classList.remove('mobile-hide');
        nav.classList.add('mobile-show');
      }, 400);

      triggered = true;
    }

    if (current < 120) {
      nav.classList.remove('mobile-show');
      triggered = false;
    }

    lastScroll = current;
  });
});
</script>


  </body>
</html>
