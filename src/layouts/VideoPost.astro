---
import type { CollectionEntry } from 'astro:content'
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import HeaderImage from '../components/HeaderImage.astro'

type Props = CollectionEntry<'video'>['data']

const { title, description, keywords } = Astro.props
---

<html lang="uk-UA" class="js-on csstransforms csstransforms3d csstransitions">
  <head>
    <BaseHead {title} {keywords} {description} />
  </head>
  <body id="top" class="boxed stickymenu stickyfooter" style="">
    <script type="text/javascript" src="/js/addthis_widget.js" async="async"></script>
    <div id="wrapper" style="margin-bottom: 75px;">
      <Header activeMenu="video" />

      <HeaderImage title="Відео" imageSrc="/media/blog.jpg" />

      <div id="main" class="wrapper">
        <div class="main-content container commonpage">
          <h2 class="main-title"></h2>
          <slot />
        </div>
      </div>
      <Footer />
    </div>
    <button id="mobileScrollTop" title="Вгору"></button>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const btn = document.getElementById('mobileScrollTop');
  if (!btn) return;

  window.addEventListener('scroll', () => {
    if (window.innerWidth <= 768) {
      if (window.scrollY > 300) {
        btn.style.opacity = '1';
        btn.style.pointerEvents = 'auto';
      } else {
        btn.style.opacity = '0';
        btn.style.pointerEvents = 'none';
      }
    }
  });

  btn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
});
</script>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const nav = document.getElementById('primary-navigation');
  if (!nav) return;

  let lastScroll = 0;
  let triggered = false;

  window.addEventListener('scroll', () => {
    const current = window.scrollY;

    // момент "дотику" до верху
    if (current > 160 && !triggered) {
      nav.classList.add('mobile-hide');

      setTimeout(() => {
        nav.classList.remove('mobile-hide');
        nav.classList.add('mobile-show');
      }, 400);

      triggered = true;
    }

    if (current < 120) {
      nav.classList.remove('mobile-show');
      triggered = false;
    }

    lastScroll = current;
  });
});
</script>
  </body>
</html>
