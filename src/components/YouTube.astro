---
const { id, title } = Astro.props;
---

<div class="video">
  <iframe
    src={`https://www.youtube.com/embed/${id}`}
    title={title}
    loading="lazy"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen>
  </iframe>
</div>

<style>
.video {
  width: 100%;
  aspect-ratio: 16 / 9;
  margin: 1.5rem 0;
}
.video iframe {
  width: 100%;
  height: 100%;
  border: 0;
  border-radius: 12px;
}
</style>
