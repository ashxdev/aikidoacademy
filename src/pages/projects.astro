---
import MainLayout from '../layouts/MainLayout.astro'
import HeaderImage from '../components/HeaderImage.astro'

const projects = [

  {
    title: 'Літні табори',
    slug: '/blog/2026/camps',
    image: 'https://res.cloudinary.com/du5rp9nvc/image/upload/v1779634727/camp5_zv7o8o.jpg',
    description: 'Літні айкідо табори'
  },
   {
    title: 'Aikido for Ukraine',
    slug: '/blog/-2025/ajkidoforukraine',
    image: 'https://res.cloudinary.com/du5rp9nvc/image/upload/v1779640743/afu_xlknvf.png',
    description: 'Міжнародний проєкт підтримки'
  },
  {
    title: 'Перший дитячий семінар з айкідо',
    slug: '/blog/-2025/pershij-dityachij-seminar-z-ajkido',
    image: '/media/Dityachij-seminar-ajkido_article_image300x239.jpg',
    description: 'Дитячий семінар з айкідо'
  },

  {
    title: 'Айкідо 0-24',
    slug: '/blog/-2025/ajkido-0-24',
    image: '/media/aikido-0-24_article_image300x239.jpg',
    description: 'Айкідо марафон'
  },
]
---

<MainLayout
  activeMenu="projects"
  title="Наші проєкти"
  description="Наші проєкти"
  keywords="Наші проєкти"
>

  <HeaderImage
    title="Наші проєкти"
    imageSrc="/media/header_project.jpg"
  />

  <div id="main" class="wrapper">
    <div class="main-content container commonpage">

      <h2 class="main-title">Наші проєкти</h2>

      <div class="blog">
        <ul class="projects-grid">

          {
            projects.map((project) => (
              <li class="post has-overlay">

                <div class="post-inner">

                  <div class="post-header">
                    <a href={project.slug}>
                      <img
                        src={project.image}
                        alt={project.title}
                      />
                    </a>
                  </div>

                  <div class="post-body">
                    <h2>
                      <a href={project.slug}>
                        {project.title}
                      </a>
                    </h2>

                    <div class="post-excerpt">
                      {project.description}
                    </div>
                  </div>

                </div>

              </li>
            ))
          }

        </ul>
      </div>

    </div>
  </div>

</MainLayout>

<style>
.projects-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30px;

  list-style: none;
  padding: 0;
  margin: 0;
}

/* Прибираємо старий float layout */
.projects-grid > li.post {
  width: auto !important;
  float: none !important;
  margin: 0 !important;
}

.projects-grid .post-inner {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.projects-grid .post-body {
  flex: 1;
}

/* Однакова висота картинок */
.projects-grid .post-header {
  height: 260px;
  overflow: hidden;
}

.projects-grid .post-header img {
  width: 100%;
  height: 100%;
  object-fit: cover;

  transition: transform 0.3s ease;
}

.projects-grid .post-header img:hover {
  transform: scale(1.03);
}

/* Опис */
.projects-grid .post-excerpt {
  line-height: 1.4em;
  margin-top: 10px;
}

/* Mobile */
@media (max-width: 768px) {
  .projects-grid {
    grid-template-columns: 1fr;
  }
}
</style>