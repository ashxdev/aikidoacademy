---
import MainLayout from '../layouts/MainLayout.astro'
import HeaderImage from '../components/HeaderImage.astro'

const projects = [

  {
    title: 'Літні табори',
    slug: '/blog/2026/camps',
    image: 'https://res.cloudinary.com/du5rp9nvc/image/upload/v1779634727/camp5_zv7o8o.jpg',
    description: 'Літні айкідо табори'
  },

  {
    title: 'Aikido for Ukraine',
    slug: '/blog/-2025/ajkidoforukraine',
    image: 'https://res.cloudinary.com/du5rp9nvc/image/upload/v1779640743/afu_xlknvf.png',
    description: 'Міжнародний проєкт підтримки'
  },

  {
    title: 'Перший дитячий семінар з айкідо',
    slug: '/blog/-2025/pershij-dityachij-seminar-z-ajkido',
    image: '/media/Dityachij-seminar-ajkido_article_image300x239.jpg',
    description: 'Дитячий семінар з айкідо'
  },

  {
    title: 'Айкідо 0-24',
    slug: '/blog/-2025/ajkido-0-24',
    image: '/media/aikido-0-24_article_image300x239.jpg',
    description: 'Айкідо марафон'
  },
]
---

<MainLayout
  activeMenu="projects"
  title="Наші проєкти"
  description="Наші проєкти"
  keywords="Наші проєкти"
>

  <HeaderImage
    title="Наші проєкти"
    imageSrc="/media/header_project.jpg"
  />

  <div id="main" class="wrapper">
    <div class="main-content container commonpage">

      <h2 class="main-title">Наші проєкти</h2>

      <div class="blog">
        <ul class="projects-grid">

          {
            projects.map((project) => (
              <li class="post has-overlay">

                <div class="post-inner">

                  <div class="post-header">
                    <a href={project.slug}>
                      <img
                        src={project.image}
                        alt={project.title}
                      />
                    </a>
                  </div>

                  <div class="post-body">
                    <h2>
                      <a href={project.slug}>
                        {project.title}
                      </a>
                    </h2>

                    <div class="post-excerpt">
                      {project.description}
                    </div>
                  </div>

                </div>

              </li>
            ))
          }

        </ul>
      </div>

      <div class="projects-text">

  <h3>Більше ніж просто тренування</h3>

  <p>
    Академія Айкідо Айкікай протягом багатьох років
    реалізовує освітні, дитячі та міжнародні проєкти,
    які об’єднують людей навколо практики айкідо,
    розвитку та спільних цінностей.
  </p>

  <p>
    Літні табори, міжнародні семінари, дитячі заходи,
    марафони та спільні тренування допомагають
    створювати середовище, у якому люди можуть
    розвиватися не лише фізично, а й особистісно.
  </p>

  <p>
    Завдяки підтримці друзів та партнерів з України
    та Європи ми продовжуємо розвивати нові
    ініціативи та робити наші проєкти доступнішими
    для дітей та дорослих.
  </p>

</div>
<div class="support-block">
      <h3>Підтримати проєкти Академії</h3>

  <p>
    Якщо ви бажаєте підтримати розвиток наших дитячих,
    освітніх та міжнародних проєктів — будемо щиро
    вдячні за допомогу.
  </p>

  <p>
    Ваша підтримка допомагає нам організовувати
    семінари, літні табори, міжнародні заходи та
    розвивати айкідо в Україні.
  </p>

  <a
    href="https://send.monobank.ua/jar/23V1tvUYFe"
    target="_blank"
    class="support-button"
  >
    Підтримати проєкти
  </a>
    </div>
  </div>
  
</div>

</MainLayout>

<style>
.projects-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30px;

  list-style: none;
  padding: 0;
  margin: 0;
}

/* Прибираємо старий float layout */
.projects-grid > li.post {
  width: auto !important;
  float: none !important;
  margin: 0 !important;
}

.projects-grid .post-inner {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.projects-grid .post-body {
  flex: 1;
}

/* Однакова висота картинок */
.projects-grid .post-header {
  height: 260px;
  overflow: hidden;
}

.projects-grid .post-header img {
  width: 100%;
  height: 100%;
  object-fit: cover;

  transition: transform 0.3s ease;
}

.projects-grid .post-header img:hover {
  transform: scale(1.03);
}

/* Опис */
.projects-grid .post-excerpt {
  line-height: 1.4em;
  margin-top: 10px;
}

/* Текстовий блок */
.projects-text {
  margin-top: 70px;
  max-width: 900px;
}

.projects-text h3 {
  margin-bottom: 25px;
}

.projects-text p {
  margin-bottom: 22px;
  line-height: 1.8;
}

/* Mobile */
@media (max-width: 768px) {
  .projects-grid {
    grid-template-columns: 1fr;
  }

  .projects-text {
    margin-top: 50px;
  }
}
.support-block {
  margin-top: 50px;

  max-width: 900px;
  margin-left: auto;
  margin-right: auto;

  padding: 50px 40px;

  background: #f5f5f5;
  border-radius: 14px;

  text-align: center;
}

.support-block h3 {
  margin-bottom: 20px;
}

.support-block p {
  max-width: 700px;
  margin: 0 auto 20px auto;

  line-height: 1.8;
}

.support-button {
  display: inline-block;

  margin-top: 15px;
  padding: 14px 32px;

  background: #111;
  color: #fff !important;

  text-decoration: none;
  border-radius: 10px;

  font-weight: 600;

  transition: 0.3s ease;
}

.support-button:hover {
  transform: translateY(-2px);
  opacity: 0.9;
}
</style>