---
import MainLayout from '../../layouts/MainLayout.astro'
import { getCollection } from 'astro:content'
import HeaderImage from '../../components/HeaderImage.astro'
import FormattedDate from '../../components/FormattedDate.astro'

const posts = (await getCollection('blog')).sort(
  (a, b) =>
    new Date(b.data.pubDate ?? 0).getTime() -
    new Date(a.data.pubDate ?? 0).getTime()
)
---

<MainLayout title="Новини" description="Новини" keywords="Новини">
  <HeaderImage title="Новини" imageSrc="/media/blog.jpg" />

  <div id="main" class="wrapper">
    <div class="main-content container commonpage">
      <h2 class="main-title">Новини</h2>
      <div class="blog">
        <ul class="blog-grid">
{
  posts.map((post) => (
    <li class="post span6 has-overlay">
      <div class="post-inner">
        <div class="post-header">
          <a href={`/blog/${post.slug}`}>
            <img src={post.data.heroImage} alt={post.data.title} />
          </a>
        </div>

        <div class="post-body">
          <div>
            <FormattedDate date={post.data.pubDate ?? new Date()} />
          </div>

          <h2>
            <a href={`/blog/${post.slug}`}>{post.data.title}</a>
          </h2>

          <div class="post-excerpt">
            {post.data.description}
          </div>
        </div>
      </div>
    </li>
  ))
}

        </ul>
      </div>
    </div>
  </div>
</MainLayout>

<style>
/* === Real 2-column grid for news page === */

.blog-grid {
  display: grid !important;
  grid-template-columns: repeat(2, 1fr);
  gap: 30px;
  list-style: none;
  padding: 0;
  margin: 0;
}

/* Вимикаємо спадщину теми */
.blog-grid > li.post {
  width: auto !important;
  float: none !important;
  margin: 0 !important;
}

/* Однакова висота карток */
.blog-grid .post-inner {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.blog-grid .post-body {
  flex: 1;
}

/* === Обмеження опису до 2 рядків === */
.blog-grid .post-excerpt {
  line-height: 1.4em;
  height: 2.8em;
  overflow: hidden;
}

/* === Однакова висота картинок === */
.blog-grid .post-header {
  height: 230px;
  overflow: hidden;
}

.blog-grid .post-header img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Mobile */
@media (max-width: 768px) {
  .blog-grid {
    grid-template-columns: 1fr;
  }
}
</style>

