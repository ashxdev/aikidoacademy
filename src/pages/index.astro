---
import YouTube from '../components/YouTube.astro'
import Layout from '../layouts/HomeLayout.astro'
---

<Layout title="Головна" description="Головна">
  <div id="header-panel">
    <div class="header-overlay"></div>
    <div class="rev-slider slider fullwidth">
      <div class="fullwidthbanner-container">
        <div class="fullwidthabnner">
          <ul>
            <li data-transition="3dcurtain-horizontal" data-slotamount="1">
              <img src="/media/stefan-summer-2018.jpg" width="1020" height="570" alt="" />
              <div class="caption sfb tp-caption start" data-speed="600" data-start="2200" data-easing="easeOutBack" data-x="865" data-y="478">
                <a href="blog/-2025/letnyaya-shkola-shihana-stefana-stenudda-v-uzhgorode-2018" class="btn-large btn-style1">Details</a>
              </div>
            </li>

            <li data-transition="fade" data-slotamount="1">
              <img src="/media/0-24.jpg" width="1020" height="570" alt="" />
              <div class="caption sfb tp-caption start" data-speed="600" data-start="2200" data-easing="easeOutBack" data-x="865" data-y="478">
                <a href="blog/-2025/international-24-hour-aikido-marathon" class="btn-large btn-style1">Details</a>
              </div>
            </li>

            <li data-transition="slidevertical" data-slotamount="1">
              <img src="/media/bruno.jpg" width="1020" height="570" alt="" />
              <div class="caption sfb tp-caption start" data-speed="600" data-start="2200" data-easing="easeOutBack" data-x="865" data-y="478">
                <a href="/blog/-2025/ceminar-bruno-gonzalesa-6-dan-ajkido-ajkikaj-franciya" class="btn-large btn-style1">Details</a>
              </div>
            </li>

            <li data-transition="3dcurtain-horizontal" data-slotamount="1">
              <img src="/media/stefan.jpg" width="1021" height="570" alt="" />
              <div class="caption sfb tp-caption start" data-speed="600" data-start="2200" data-easing="easeOutBack" data-x="865" data-y="478">
                <a href="/blog/-2025/ceminar-shihana-stefana-stenudda" class="btn-large btn-style1">Details</a>
              </div>
            </li>
          </ul>
        </div>
      </div>

      <a href="#" class="slider-control-prev"></a>
      <a href="#" class="slider-control-next"></a>
    </div>
  </div>

  <div class="main-content frontpage">

    <div id="hide-info-container" class="row">
      <!-- ТУТ ТВОЇ hide-info-box-и БЕЗ ЗМІН -->
    </div>

    <div class="home-clean">

      <section class="home-section">
        <div class="section-line"></div>
        <div class="section-head">
          <h2>Новини</h2>
          <a href="/blog">Всі новини »</a>
        </div>

        <div class="home-grid-3">
          <a class="home-card" href="https://aikidoacademy.com.ua/blog/2025/mmnmm/">
            <img src="/blog/2025/mmnmm-7.jpg" />
            <h3>Дружба в дії</h3>
          </a>

          <a class="home-card" href="https://aikidoacademy.com.ua/blog/-2025/kniga-yaku-varto-prochitati/">
            <img src="/blog/Kniga-yaku-varto-prochitati.jpg" />
            <h3>Книга, яку варто прочитати</h3>
          </a>

          <a class="home-card" href="https://aikidoacademy.com.ua/blog/2025/pikuj/">
            <img src="/blog/2025/pikuj.jpg" />
            <h3>За межами залу</h3>
          </a>
        </div>
      </section>

      <section class="home-section">
        <div class="section-line"></div>
        <div class="section-head">
          <h2>Наші відео</h2>
          <a href="/video">Більше відео »</a>
        </div>

        <div class="home-grid-3">
          <YouTube id="xwj6n4Knu1k" title="Seminar aikido with Stefan Stenudd 2023" />
          <YouTube id="HEts2erkrqU" title="Aikido Demonstration 17.02.2024" />
          <YouTube id="cjVac_93B-o" title="Smerekovo AikiCamp 2025" />
        </div>
      </section>

    </div>
  </div>

</Layout>


<style>
.home-section {
  max-width: 1020px;
  margin: 40px auto;
  padding: 0 10px;
}

/* заголовок + лінк */
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
}

.section-head h2 {
  margin: 0;
  font-size: 28px;
  text-transform: uppercase;
  flex: 1;
  text-align: center;
}


.section-head a {
  color: #313131;
  text-decoration: none;
}

.section-head a:hover {
  color: #1eb0bc;
}

/* 3 колонки */
.home-grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

/* картки новин */
.home-card {
  text-decoration: none;
  color: inherit;
}

.home-card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
  border-radius: 8px;
}

.home-card h3 {
  text-align: center;
  margin-top: 10px;
  font-size: 18px;
}

/* мобільний */
@media (max-width: 768px) {
  .section-head {
    flex-direction: column;
    gap: 8px;
    text-align: center;
  }

  .home-grid-3 {
    grid-template-columns: 1fr;
  }
}

.section-head {
  position: relative;
  margin-bottom: 25px;
  padding-bottom: 10px;
}

.section-line {
  height: 2px;
  background: #e5e5e5;
  margin: 12px 0 20px;
}

.section-head h2 {
  border-bottom: none !important;
}
</style>
